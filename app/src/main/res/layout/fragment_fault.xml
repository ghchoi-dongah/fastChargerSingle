<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="1000dp"
    android:layout_height="676dp"
    tools:context=".pages.FaultFragment">

    <TextView
        android:id="@+id/txtFaultTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="System Error Message"
        android:drawablePadding="30dp"
        android:textColor="@color/black_500"
        android:textStyle="bold"
        android:textSize="42sp"
        android:layout_marginTop="20dp"
        app:drawableStartCompat="@drawable/fault"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/txtFaultMessage"
        android:layout_width="970dp"
        android:layout_height="520dp"
        android:layout_marginTop="10dp"
        android:textSize="28sp"
        android:textColor="#ffffff"
        android:gravity="left"
        android:background="@drawable/textview_edge_back"
        app:layout_constraintTop_toBottomOf="@id/txtFaultTitle"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        tools:ignore="RtlHardcoded" />


</androidx.constraintlayout.widget.ConstraintLayout>