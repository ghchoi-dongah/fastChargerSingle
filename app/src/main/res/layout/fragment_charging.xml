<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="1024dp"
    android:layout_height="676dp"
    tools:context=".pages.ChargingFragment">
    <!-- header height: 70dp / bottom height: 18dp  -->

    <TextView
        android:id="@+id/textViewChargingMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/chargingMessage"
        android:textSize="38sp"
        android:gravity="center"
        android:layout_marginTop="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>


    <TextView
        android:id="@+id/txtSoc"
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="220dp"
        android:gravity="center_horizontal"
        android:text="100%"
        android:textSize="96sp"
        android:textStyle="bold"
        android:layout_marginTop="80dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>


    <ImageView
        android:id="@+id/imageLeftTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="30dp"
        android:layout_marginTop="20dp"
        android:src="@drawable/lefttime"
        app:layout_constraintTop_toTopOf="@id/txtSoc"
        app:layout_constraintStart_toEndOf="@id/txtSoc"
        app:layout_constraintBottom_toBottomOf="@id/txtSoc"
        tools:ignore="contentDescription" />

    <TextView
        android:id="@+id/textViewLeftTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:gravity="center_vertical"
        android:text="@string/remainTime"
        android:textSize="24sp"
        app:layout_constraintTop_toTopOf="@id/imageLeftTime"
        app:layout_constraintStart_toEndOf="@id/imageLeftTime"
        app:layout_constraintBottom_toBottomOf="@id/imageLeftTime"/>

    <TextView
        android:id="@+id/txtRemainTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:gravity="end"
        android:text="00:00:00"
        android:textSize="22sp"
        app:layout_constraintTop_toTopOf="@id/textViewLeftTime"
        app:layout_constraintStart_toEndOf="@id/textViewLeftTime"
        app:layout_constraintBottom_toBottomOf="@id/textViewLeftTime"/>


    <androidx.cardview.widget.CardView
        xmlns:card_view="http://schemas.android.com/apk/res-auto"
        android:id="@+id/cardView"
        android:layout_width="780dp"
        android:layout_height="160dp"
        app:cardBackgroundColor="#F5F7F8"
        card_view:layout_constraintTop_toBottomOf="@id/txtSoc"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        card_view:cardCornerRadius="16dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:padding="4dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            >

            <ImageView
                android:id="@+id/imageAmountUsed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="50dp"
                android:src="@drawable/charge_amount"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/textViewAmountUsedContent"
                app:layout_constraintBottom_toBottomOf="@id/txtAmountOfCharge"
                tools:ignore="contentDescription" />

            <TextView
                android:id="@+id/textViewAmountUsedContent"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginTop="38dp"
                android:layout_marginStart="20dp"
                android:textColor="@color/gin_grey"
                android:text="@string/charge_of_amount"
                android:textSize="26sp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toEndOf="@id/imageAmountUsed"/>

            <TextView
                android:id="@+id/txtAmountOfCharge"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginTop="6dp"
                android:gravity="start"
                android:text="70kWh"
                android:textSize="32sp"
                app:layout_constraintTop_toBottomOf="@id/textViewAmountUsedContent"
                app:layout_constraintStart_toStartOf="@id/textViewAmountUsedContent" />


            <ImageView
                android:id="@+id/imageMoney"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="290dp"
                android:src="@drawable/money"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/textViewMoneyContent"
                app:layout_constraintBottom_toBottomOf="@id/txtChargePay"
                tools:ignore="contentDescription" />

            <TextView
                android:id="@+id/textViewMoneyContent"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:gravity="center_vertical"
                android:layout_marginTop="38dp"
                android:layout_marginStart="20dp"
                android:textColor="@color/gin_grey"
                android:text="@string/charge_amount"
                android:textSize="28sp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toEndOf="@id/imageMoney"/>

            <TextView
                android:id="@+id/txtChargePay"
                android:layout_width="150dp"
                android:layout_height="wrap_content"
                android:gravity="right"
                android:text="20,000원"
                android:textSize="32sp"
                app:layout_constraintTop_toBottomOf="@id/textViewMoneyContent"
                app:layout_constraintStart_toStartOf="@id/textViewMoneyContent" />


            <ImageView
                android:id="@+id/imageTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="540dp"
                android:src="@drawable/time"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/textViewTimeContent"
                app:layout_constraintBottom_toBottomOf="@id/txtChargeTime"
                tools:ignore="contentDescription" />

            <TextView
                android:id="@+id/textViewTimeContent"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginTop="38dp"
                android:layout_marginStart="20dp"
                android:textColor="@color/gin_grey"
                android:text="@string/charging_time"
                android:textSize="28sp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toEndOf="@id/imageTime"/>

            <TextView
                android:id="@+id/txtChargeTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="start"
                android:text="00:22:12"
                android:textSize="32sp"
                app:layout_constraintTop_toBottomOf="@id/textViewTimeContent"
                app:layout_constraintStart_toStartOf="@id/textViewTimeContent" />


        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>



    <TextView
        android:id="@+id/textViewVoltage"
        android:layout_width="150dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginTop="20dp"
        android:text="@string/outVoltage"
        android:textSize="22sp"
        app:layout_constraintTop_toBottomOf="@id/cardView"
        app:layout_constraintStart_toStartOf="@id/cardView" />

    <TextView
        android:id="@+id/txtOutVoltage"
        android:layout_width="160dp"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:text="0"
        android:textSize="22sp"
        app:layout_constraintTop_toTopOf="@id/textViewVoltage"
        app:layout_constraintStart_toEndOf="@id/textViewVoltage"
        app:layout_constraintBottom_toBottomOf="@id/textViewVoltage"/>

    <TextView
        android:id="@+id/textViewAmount"
        android:layout_width="150dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/outCurrent"
        android:textSize="22sp"
        app:layout_constraintTop_toBottomOf="@id/textViewVoltage"
        app:layout_constraintStart_toStartOf="@id/textViewVoltage" />

    <TextView
        android:id="@+id/txtOutCurrent"
        android:layout_width="160dp"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:text="0"
        android:textSize="22sp"
        app:layout_constraintTop_toTopOf="@id/textViewAmount"
        app:layout_constraintStart_toEndOf="@id/textViewAmount"
        app:layout_constraintBottom_toBottomOf="@id/textViewAmount"/>

    <TextView
        android:id="@+id/textViewPower"
        android:layout_width="150dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/outPower"
        android:textSize="22sp"
        app:layout_constraintTop_toBottomOf="@id/textViewAmount"
        app:layout_constraintStart_toStartOf="@id/textViewAmount"/>

    <TextView
        android:id="@+id/txtOutPower"
        android:layout_width="160dp"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:text="0"
        android:textSize="22sp"
        app:layout_constraintTop_toTopOf="@id/textViewPower"
        app:layout_constraintStart_toEndOf="@id/textViewPower"
        app:layout_constraintBottom_toBottomOf="@id/textViewPower"/>

    <TextView
        android:id="@+id/textViewPrePayment"
        android:layout_width="180dp"
        android:layout_height="wrap_content"
        android:text="@string/recharge_unit_price"
        android:textSize="22sp"
        app:layout_constraintTop_toTopOf="@id/txtPrepayment"
        app:layout_constraintEnd_toStartOf="@id/txtPrepayment"/>

    <TextView
        android:id="@+id/txtPrepayment"
        android:layout_width="180dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="10dp"
        android:layout_marginTop="20dp"
        android:gravity="end"
        android:text="0"
        android:textSize="22sp"
        app:layout_constraintTop_toBottomOf="@id/cardView"
        app:layout_constraintEnd_toEndOf="@id/cardView"/>


    <TextView
        android:id="@+id/textViewunit"
        android:layout_width="180dp"
        android:layout_height="wrap_content"
        android:text="@string/chargingUnit"
        android:textSize="22sp"
        app:layout_constraintTop_toTopOf="@id/txtUnitPrice"
        app:layout_constraintEnd_toStartOf="@id/txtUnitPrice"/>

    <TextView
        android:id="@+id/txtUnitPrice"
        android:layout_width="180dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="10dp"
        android:gravity="end"
        android:text="0"
        android:textSize="22sp"
        app:layout_constraintTop_toTopOf="@id/txtOutCurrent"
        app:layout_constraintBottom_toBottomOf="@id/txtOutCurrent"
        app:layout_constraintEnd_toEndOf="@id/cardView"/>


    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnChargingStop"
        android:layout_width="380dp"
        android:layout_height="90dp"
        android:background="@drawable/rounded_blue_button"
        android:gravity="center"
        android:textColor="@color/white"
        android:text="@string/chargingStopMessage"
        android:textSize="45sp"
        android:layout_marginTop="30dp"
        app:layout_constraintTop_toBottomOf="@id/txtOutPower"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>