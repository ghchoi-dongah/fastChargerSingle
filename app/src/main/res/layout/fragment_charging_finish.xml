<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="1024dp"
    android:layout_height="676dp"
    tools:context=".pages.ChargingFinishFragment">

    <View
        android:id="@+id/view"
        android:layout_width="730dp"
        android:layout_height="match_parent"
        android:layout_marginHorizontal="10dp"
        android:layout_marginTop="5dp"
        android:layout_marginBottom="29dp"
        android:background="@drawable/layer_list_rect"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/textViewChargingFinishMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:gravity="center"
        android:text="@string/chargingFinish"
        android:textSize="44sp"
        android:textColor="@color/black"
        app:layout_constraintEnd_toEndOf="@id/view"
        app:layout_constraintStart_toStartOf="@id/view"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- 1. 배경용 -->
    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/progressBackground"
        android:layout_width="265dp"
        android:layout_height="265dp"
        app:indicatorSize="265dp"
        app:trackThickness="22dp"
        app:indicatorColor="#EEEEEE"
        android:progress="100"
        app:layout_constraintTop_toTopOf="@id/progressCircular"
        app:layout_constraintBottom_toBottomOf="@id/progressCircular"
        app:layout_constraintStart_toStartOf="@id/progressCircular"
        app:layout_constraintEnd_toEndOf="@id/progressCircular" />

    <!-- 2. 실제 게이지 -->
    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/progressCircular"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_marginTop="60dp"
        android:progress="60"
        app:indicatorSize="280dp"
        app:trackThickness="34dp"
        app:indicatorColor="@color/primary"
        app:trackCornerRadius="6dp"
        app:trackColor="@android:color/transparent"
        app:layout_constraintTop_toBottomOf="@id/textViewChargingFinishMessage"
        app:layout_constraintStart_toStartOf="@id/view"
        app:layout_constraintEnd_toEndOf="@id/view" />

    <TextView
        android:id="@+id/txtProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:text="100%"
        android:textSize="60sp"
        android:textColor="@color/black"
        app:layout_constraintTop_toTopOf="@id/progressCircular"
        app:layout_constraintStart_toStartOf="@id/progressCircular"
        app:layout_constraintEnd_toEndOf="@id/progressCircular"
        app:layout_constraintBottom_toBottomOf="@id/progressCircular" />


    <TextView
        android:id="@+id/textViewChargingFinishSubMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/connectorDisconnectMessage"
        android:textSize="24sp"
        app:layout_constraintTop_toBottomOf="@id/progressCircular"
        app:layout_constraintEnd_toEndOf="@id/view"
        app:layout_constraintStart_toStartOf="@id/view"
        app:layout_constraintBottom_toBottomOf="@id/view"/>

    <androidx.cardview.widget.CardView
        android:id="@+id/cardView1"
        android:layout_width="270dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="4dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toTopOf="@id/view"
        app:layout_constraintStart_toEndOf="@id/view"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/shape_card_bg"
            android:paddingHorizontal="20dp"
            android:paddingVertical="10dp">

            <TextView
                android:id="@+id/textViewInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/chargingInfo"
                android:textColor="@color/black"
                android:textSize="17sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <View
                android:id="@+id/viewLine1"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:layout_marginTop="5dp"
                android:background="#E7E7E7"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/textViewInfo" />

            <TextView
                android:id="@+id/textViewTimeContentUsedContent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="@string/charge_of_amount"
                android:textSize="17sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/viewLine1" />

            <TextView
                android:id="@+id/txtAmountOfCharge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="70kWh"
                android:textColor="@color/black_500"
                android:textSize="17sp"
                app:layout_constraintBottom_toBottomOf="@id/textViewTimeContentUsedContent"
                app:layout_constraintEnd_toEndOf="@id/viewLine1"
                app:layout_constraintTop_toTopOf="@id/textViewTimeContentUsedContent" />

            <TextView
                android:id="@+id/textViewMoneyContent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="@string/charge_amount"
                android:textSize="17sp"
                app:layout_constraintStart_toStartOf="@id/textViewTimeContentUsedContent"
                app:layout_constraintTop_toBottomOf="@id/textViewTimeContentUsedContent" />

            <TextView
                android:id="@+id/txtActualPayment"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="20,000원"
                android:textColor="@color/black_500"
                android:textSize="17sp"
                app:layout_constraintBottom_toBottomOf="@id/textViewMoneyContent"
                app:layout_constraintEnd_toEndOf="@id/txtAmountOfCharge"
                app:layout_constraintTop_toTopOf="@id/textViewMoneyContent" />

            <TextView
                android:id="@+id/textViewTimeContent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="@string/charging_time"
                android:textSize="17sp"
                app:layout_constraintStart_toStartOf="@id/textViewTimeContentUsedContent"
                app:layout_constraintTop_toBottomOf="@id/textViewMoneyContent" />

            <TextView
                android:id="@+id/txtChargeTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00:00"
                android:textColor="@color/black_500"
                android:textSize="17sp"
                app:layout_constraintBottom_toBottomOf="@id/textViewTimeContent"
                app:layout_constraintEnd_toEndOf="@id/txtAmountOfCharge"
                app:layout_constraintTop_toTopOf="@id/textViewTimeContent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>


    <androidx.cardview.widget.CardView
        android:id="@+id/cardView2"
        android:layout_width="270dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="4dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/cardView1"
        app:layout_constraintStart_toEndOf="@id/view"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/shape_card_bg"
            android:paddingHorizontal="20dp"
            android:paddingVertical="10dp">

            <TextView
                android:id="@+id/textViewPayInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/payInfo"
                android:textColor="@color/black"
                android:textSize="17sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <View
                android:id="@+id/viewLine2"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:layout_marginTop="5dp"
                android:background="#E7E7E7"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/textViewPayInfo" />

            <TextView
                android:id="@+id/textViewPrePayment"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="@string/recharge_unit_price"
                android:textSize="17sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/viewLine2" />

            <TextView
                android:id="@+id/txtPrepayment"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/black_500"
                android:textSize="17sp"
                app:layout_constraintBottom_toBottomOf="@id/textViewPrePayment"
                app:layout_constraintEnd_toEndOf="@id/viewLine2"
                app:layout_constraintTop_toTopOf="@id/textViewPrePayment" />

            <TextView
                android:id="@+id/textViewCancelPayment"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="@string/PartCancelPay"
                android:textSize="17sp"
                app:layout_constraintStart_toStartOf="@id/textViewPrePayment"
                app:layout_constraintTop_toBottomOf="@id/textViewPrePayment" />

            <TextView
                android:id="@+id/txtPaymentReturn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/black_500"
                android:textSize="17sp"
                app:layout_constraintBottom_toBottomOf="@id/textViewCancelPayment"
                app:layout_constraintEnd_toEndOf="@id/txtPrepayment"
                app:layout_constraintTop_toTopOf="@id/textViewCancelPayment" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnStopConfirm"
        android:layout_width="270dp"
        android:layout_height="160dp"
        android:layout_marginBottom="4dp"
        android:text="@string/btn_confirm_text"
        android:background="@drawable/shape_btn_blue"
        android:textSize="34sp"
        android:textColor="@color/white"
        android:textStyle="bold"
        app:backgroundTint="@null"
        app:layout_constraintBottom_toBottomOf="@id/view"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/view"/>

</androidx.constraintlayout.widget.ConstraintLayout>
