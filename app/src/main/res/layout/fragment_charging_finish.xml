<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="1000dp"
    android:layout_height="676dp"
    tools:context=".pages.ChargingFinishFragment">

    <!-- TODO: Update blank fragment layout -->

    <TextView
        android:id="@+id/textViewChargingFinishMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/chargingFinish"
        android:textSize="36sp"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/textViewChargingFinishSubMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/chargingFinishMessage"
        android:textSize="24sp"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textViewChargingFinishMessage"/>

    <TextView
        android:id="@+id/txtProgress"
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:text="100%"
        android:textSize="96sp"
        android:textStyle="bold"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.22"/>



    <androidx.cardview.widget.CardView
        android:id="@+id/cardView"
        android:layout_width="780dp"
        android:layout_height="160dp"
        app:cardBackgroundColor="#F5F7F8"
        app:layout_constraintTop_toBottomOf="@id/txtProgress"
        android:layout_marginTop="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintVertical_bias="0.46"
        app:cardCornerRadius="16dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:padding="4dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            >

            <ImageView
                android:id="@+id/imageAmountUsed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="30dp"
                android:src="@drawable/charge_amount"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/textViewAmountUsedContent"
                app:layout_constraintBottom_toBottomOf="@id/txtAmountOfCharge"
                tools:ignore="contentDescription" />

            <TextView
                android:id="@+id/textViewAmountUsedContent"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginStart="20dp"
                android:layout_marginTop="36dp"
                android:text="@string/charge_of_amount"
                android:textColor="@color/gin_grey"
                android:textSize="26sp"
                app:layout_constraintStart_toEndOf="@id/imageAmountUsed"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/txtAmountOfCharge"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginTop="6dp"
                android:gravity="start"
                android:text="70kWh"
                android:textSize="32sp"
                app:layout_constraintTop_toBottomOf="@id/textViewAmountUsedContent"
                app:layout_constraintStart_toStartOf="@id/textViewAmountUsedContent" />


            <ImageView
                android:id="@+id/imageMoney"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="260dp"
                android:src="@drawable/money"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/textViewMoneyContent"
                app:layout_constraintBottom_toBottomOf="@id/txtActualPayment"
                tools:ignore="contentDescription" />

            <TextView
                android:id="@+id/textViewMoneyContent"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:gravity="center_vertical"
                android:layout_marginTop="38dp"
                android:layout_marginStart="20dp"
                android:textColor="@color/gin_grey"
                android:text="@string/charge_amount"
                android:textSize="28sp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toEndOf="@id/imageMoney"/>

            <TextView
                android:id="@+id/txtActualPayment"
                android:layout_width="150dp"
                android:layout_height="wrap_content"
                android:gravity="right"
                android:text="20,000원"
                android:textSize="32sp"
                app:layout_constraintTop_toBottomOf="@id/textViewMoneyContent"
                app:layout_constraintStart_toStartOf="@id/textViewMoneyContent" />


            <ImageView
                android:id="@+id/imageTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="520dp"
                android:src="@drawable/time"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/textViewTimeContent"
                app:layout_constraintBottom_toBottomOf="@id/txtChargeTime"
                tools:ignore="contentDescription" />

            <TextView
                android:id="@+id/textViewTimeContent"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginTop="38dp"
                android:layout_marginStart="20dp"
                android:textColor="@color/gin_grey"
                android:text="@string/charging_time"
                android:textSize="28sp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toEndOf="@id/imageTime"/>

            <TextView
                android:id="@+id/txtChargeTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="start"
                android:text="00:22:12"
                android:textSize="32sp"
                app:layout_constraintTop_toBottomOf="@id/textViewTimeContent"
                app:layout_constraintStart_toStartOf="@id/textViewTimeContent" />


        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/textViewPrePayment"
        android:layout_width="150dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginTop="20dp"
        android:text="@string/recharge_unit_price"
        android:textSize="22sp"
        app:layout_constraintTop_toBottomOf="@id/cardView"
        app:layout_constraintStart_toStartOf="@id/cardView" />

    <TextView
        android:id="@+id/txtPrepayment"
        android:layout_width="160dp"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:text="0"
        android:textSize="22sp"
        app:layout_constraintTop_toTopOf="@id/textViewPrePayment"
        app:layout_constraintStart_toEndOf="@id/textViewPrePayment"
        app:layout_constraintBottom_toBottomOf="@id/textViewPrePayment"/>


    <TextView
        android:id="@+id/textViewCancelPayment"
        android:layout_width="180dp"
        android:layout_height="wrap_content"
        android:text="@string/PartCancelPay"
        android:textSize="22sp"
        app:layout_constraintTop_toTopOf="@id/txtPaymentReturn"
        app:layout_constraintEnd_toStartOf="@id/txtPaymentReturn"/>

    <TextView
        android:id="@+id/txtPaymentReturn"
        android:layout_width="180dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="10dp"
        android:layout_marginTop="20dp"
        android:gravity="end"
        android:text="0"
        android:textSize="22sp"
        app:layout_constraintTop_toBottomOf="@id/cardView"
        app:layout_constraintEnd_toEndOf="@id/cardView"/>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnStopConfirm"
        android:layout_width="380dp"
        android:layout_height="120dp"
        android:text="@string/btn_confirm_text"
        app:backgroundTint="@null"
        android:background="@drawable/rounded_white_button"
        android:textSize="40sp"
        android:textColor="@color/black"
        android:layout_marginBottom="40dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"/>


</androidx.constraintlayout.widget.ConstraintLayout>



