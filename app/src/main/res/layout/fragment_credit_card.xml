<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="1000dp"
    android:layout_height="676dp"
    tools:context=".pages.CreditCardFragment">

    <!-- TODO: Update blank fragment layout -->
    <TextView
        android:id="@+id/txtCreditMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/creditMessage"
        android:gravity="center_horizontal"
        android:textSize="44sp"
        android:layout_marginTop="50dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent" />

    <TextView
        android:id="@+id/txtPriceTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="130dp"
        android:layout_marginStart="60dp"
        android:text="@string/priceMessage"
        android:textSize="36sp"
        android:textColor="@color/black"
        app:layout_constraintTop_toBottomOf="@id/txtCreditMessage"
        app:layout_constraintLeft_toLeftOf="parent"
        tools:ignore="RtlHardcoded" />

    <TextView
        android:id="@+id/txtInputAmt"
        android:layout_width="200dp"
        android:layout_height="50dp"
        android:gravity="right|center"
        android:layout_marginStart="20dp"
        android:text="0"
        android:textSize="40sp"
        android:textColor="@color/black"
        app:layout_constraintLeft_toRightOf="@id/txtPriceTitle"
        app:layout_constraintTop_toTopOf="@id/txtPriceTitle"
        app:layout_constraintBottom_toBottomOf="@id/txtPriceTitle"
        tools:ignore="RtlHardcoded" />

    <TextView
        android:id="@+id/won"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:text="@string/payUnitMessage"
        android:textSize="34sp"
        android:textColor="@color/black"
        app:layout_constraintLeft_toRightOf="@id/txtInputAmt"
        app:layout_constraintBottom_toBottomOf="@id/txtInputAmt" />

    <View
        android:id="@+id/viewLine"
        android:layout_width="400dp"
        android:layout_height="4dp"
        android:layout_marginTop="5dp"
        android:layout_centerInParent="true"
        android:background="@color/primary"
        app:layout_constraintLeft_toLeftOf="@id/txtPriceTitle"
        app:layout_constraintTop_toBottomOf="@id/txtInputAmt" />

<!--    <TextView-->
<!--        android:id="@+id/chargeUnit"-->
<!--        android:layout_width="100dp"-->
<!--        android:layout_height="wrap_content"-->
<!--        android:layout_marginTop="10dp"-->
<!--        android:gravity="left"-->
<!--        android:text="@string/chargeUnit"-->
<!--        android:textSize="20sp"-->
<!--        app:layout_constraintLeft_toLeftOf="@+id/txtPriceTitle"-->
<!--        app:layout_constraintTop_toBottomOf="@id/txtInputAmt" />-->

    <TextView
        android:id="@+id/unitPrice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textSize="20sp"
        app:layout_constraintLeft_toLeftOf="@+id/txtPriceTitle"
        app:layout_constraintTop_toBottomOf="@id/txtInputAmt"
        tools:ignore="RtlHardcoded" />

<!--    <TextView-->
<!--        android:layout_width="wrap_content"-->
<!--        android:layout_height="wrap_content"-->
<!--        android:layout_marginTop="8dp"-->
<!--        android:layout_marginStart="10dp"-->
<!--        android:text="@string/payUnitMessage"-->
<!--        android:textColor="#999999"-->
<!--        android:textSize="20sp"-->
<!--        app:layout_constraintRight_toRightOf="@id/viewLine"-->
<!--        app:layout_constraintBottom_toBottomOf="@id/unitPrice" />-->

    <Button
        android:id="@+id/btn500"
        android:layout_width="242dp"
        android:layout_height="102dp"
        android:layout_marginStart="124dp"
        android:layout_marginTop="70dp"
        android:text="@string/btn_500"
        android:textSize="32sp"
        android:tag="500"
        android:background="@drawable/selector_default_btn"
        app:backgroundTint="@null"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toBottomOf="@id/viewLine" />

    <Button
        android:id="@+id/btn1000"
        android:layout_width="242dp"
        android:layout_height="102dp"
        android:layout_marginStart="25dp"
        android:text="@string/btn_1000"
        android:textSize="32sp"
        android:tag="1000"
        android:background="@drawable/selector_default_btn"
        app:backgroundTint="@null"
        app:layout_constraintLeft_toRightOf="@id/btn500"
        app:layout_constraintTop_toTopOf="@id/btn500" />

    <Button
        android:id="@+id/btn5000"
        android:layout_width="242dp"
        android:layout_height="102dp"
        android:layout_marginStart="25dp"
        android:text="@string/btn_5000"
        android:textSize="32sp"
        android:tag="5000"
        android:background="@drawable/selector_default_btn"
        app:backgroundTint="@null"
        app:layout_constraintLeft_toRightOf="@id/btn1000"
        app:layout_constraintTop_toTopOf="@id/btn1000" />

    <Button
        android:id="@+id/btn10000"
        android:layout_width="242dp"
        android:layout_height="102dp"
        android:layout_marginTop="15dp"
        android:text="@string/btn_10000"
        android:textSize="32sp"
        android:tag="10000"
        android:background="@drawable/selector_default_btn"
        app:backgroundTint="@null"
        app:layout_constraintLeft_toLeftOf="@id/btn500"
        app:layout_constraintTop_toBottomOf="@id/btn500" />

    <Button
        android:id="@+id/btn20000"
        android:layout_width="242dp"
        android:layout_height="102dp"
        android:layout_marginStart="25dp"
        android:text="@string/btn_20000"
        android:textSize="32sp"
        android:tag="20000"
        android:background="@drawable/selector_default_btn"
        app:backgroundTint="@null"
        app:layout_constraintLeft_toRightOf="@id/btn10000"
        app:layout_constraintTop_toTopOf="@id/btn10000" />

    <Button
        android:id="@+id/btn50000"
        android:layout_width="242dp"
        android:layout_height="102dp"
        android:layout_marginStart="25dp"
        android:text="@string/btn_Full"
        android:textSize="32sp"
        android:tag="50000"
        android:background="@drawable/selector_default_btn"
        app:backgroundTint="@null"
        app:layout_constraintLeft_toRightOf="@id/btn20000"
        app:layout_constraintTop_toTopOf="@id/btn20000" />

    <Button
        android:id="@+id/btnClear"
        android:layout_width="220dp"
        android:layout_height="100dp"
        android:layout_marginStart="50dp"
        android:layout_marginTop="100dp"
        android:text="@string/btn_clear"
        android:textSize="32sp"
        android:background="@drawable/shape_card_bg"
        app:backgroundTint="@null"
        app:layout_constraintLeft_toRightOf="@id/viewLine"
        app:layout_constraintTop_toBottomOf="@id/txtCreditMessage" />

    <Button
        android:id="@+id/btnPay"
        android:layout_width="220dp"
        android:layout_height="100dp"
        android:text="@string/btn_pay"
        app:backgroundTint="@null"
        android:textSize="32sp"
        android:layout_marginStart="20dp"
        android:background="@drawable/shape_btn_blue"
        app:layout_constraintLeft_toRightOf="@id/btnClear"
        app:layout_constraintTop_toTopOf="@id/btnClear" />

</androidx.constraintlayout.widget.ConstraintLayout>