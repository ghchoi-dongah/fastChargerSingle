<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="1000dp"
    android:layout_height="676dp"
    tools:context=".pages.MemberCardWaitFragment">

    <!-- TODO: Update blank fragment layout -->
    <TextView
        android:id="@+id/txtMemberWaiting"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/txtMemberWaiting"
        android:gravity="center_horizontal"
        android:textSize="44sp"
        android:layout_marginTop="50dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/imageViewMemberFailed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="80dp"
        android:background="@drawable/auth_error"
        android:visibility="invisible"
        app:layout_constraintTop_toBottomOf="@id/txtMemberWaiting"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:ignore="contentDescription" />

    <TextView
        android:id="@+id/textViewFailed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:text="!"
        android:textSize="60sp"
        android:textColor="#9A0C0C"
        android:textStyle="bold"
        android:visibility="invisible"
        app:layout_constraintStart_toStartOf="@id/imageViewMemberFailed"
        app:layout_constraintEnd_toEndOf="@id/imageViewMemberFailed"
        app:layout_constraintTop_toTopOf="@id/imageViewMemberFailed"
        tools:ignore="contentDescription"/>

    <com.wang.avi.AVLoadingIndicatorView
        android:id="@+id/avi"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:visibility="visible"
        app:indicatorName="BallSpinFadeLoaderIndicator"
        app:indicatorColor="@color/primary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

