<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="1000dp"
    android:layout_height="676dp"
    tools:context=".pages.MemberCardWaitFragment">

    <!-- TODO: Update blank fragment layout -->
    <TextView
        android:id="@+id/txtMemberWaiting"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/txtMemberWaiting"
        android:gravity="center_horizontal"
        android:textSize="44sp"
        android:layout_marginTop="50dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/imgMemberWaiting_bg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/membership_loading_bg"
        android:layout_marginTop="100dp"
        app:layout_constraintTop_toBottomOf="@+id/txtMemberWaiting"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        tools:ignore="ContentDescription" />

    <ImageView
        android:id="@+id/imgMemberSpinner"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:background="@drawable/loading01"
        android:layout_marginStart="208dp"
        android:layout_marginTop="25dp"
        app:layout_constraintLeft_toLeftOf="@+id/imgMemberWaiting_bg"
        app:layout_constraintTop_toTopOf="@id/imgMemberWaiting_bg"
        tools:ignore="ContentDescription" />

    <Button
        android:id="@+id/btnConfirm"
        android:layout_width="190dp"
        android:layout_height="50dp"
        android:text="@string/btn_confirm"
        app:backgroundTint="@null"
        android:textSize="19sp"
        android:layout_marginTop="40dp"
        android:visibility="invisible"
        android:background="@drawable/selector_default_btn"
        app:layout_constraintLeft_toLeftOf="@id/imgMemberWaiting_bg"
        app:layout_constraintRight_toRightOf="@id/imgMemberWaiting_bg"
        app:layout_constraintTop_toBottomOf="@id/imgMemberWaiting_bg" />


</androidx.constraintlayout.widget.ConstraintLayout>