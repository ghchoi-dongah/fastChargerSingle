<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="1000dp"
    android:layout_height="676dp"
    tools:context=".pages.InitFragment">

    <View
        android:id="@+id/viewLine"
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="#2de6d6"
        android:visibility="invisible"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.appcompat.widget.LinearLayoutCompat
        android:id="@+id/linearLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:layout_editor_absoluteX="0dp"
        tools:layout_editor_absoluteY="0dp">

        <ImageView
            android:id="@+id/bg_check"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/img_check"
            android:clickable="false"
            android:visibility="invisible" />


    </androidx.appcompat.widget.LinearLayoutCompat>

    <TextView
        android:id="@+id/creditwaitMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/creditwaitMessage"
        android:textSize="44sp"
        android:layout_marginTop="50dp"
        android:gravity="center_horizontal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent" />

    <TextView
        android:id="@+id/txtPay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/preAmtMessage"
        android:textSize="46sp"
        android:layout_marginStart="-200dp"
        android:layout_marginTop="150dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"/>

    <TextView
        android:id="@+id/txtInputAmt"
        android:layout_width="210dp"
        android:layout_height="55dp"
        android:textSize="48sp"
        android:text="0"
        android:gravity="right|center"
        android:layout_marginStart="20dp"
        android:layout_marginTop="10dp"
        app:layout_constraintLeft_toRightOf="@id/txtPay"
        app:layout_constraintTop_toTopOf="@id/txtPay"
        tools:ignore="RtlHardcoded" />

    <TextView
        android:id="@+id/won"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/payUnitMessage"
        android:textSize="28sp"
        android:layout_marginTop="11dp"
        android:layout_marginStart="10dp"
        app:layout_constraintLeft_toRightOf="@id/txtInputAmt"
        app:layout_constraintTop_toTopOf="@id/txtInputAmt" />

    <View
        android:layout_width="450dp"
        android:layout_height="1.5dp"
        android:layout_centerInParent="true"
        android:background="#224E98"
        android:layout_marginTop="5dp"
        app:layout_constraintLeft_toLeftOf="@id/txtPay"
        app:layout_constraintTop_toBottomOf="@id/txtPay" />

    <ImageView
        android:id="@+id/imageViewCreditCardBackground"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:layout_marginStart="80dp"
        android:background="@drawable/card_to_reader_background"
        app:layout_constraintLeft_toLeftOf="@id/txtPay"
        app:layout_constraintTop_toBottomOf="@id/txtInputAmt"
        tools:ignore="contentDescription" />

    <ImageView
        android:id="@+id/creditInsert"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/creditcardtagging"
        app:layout_constraintTop_toTopOf="@id/imageViewCreditCardBackground"
        app:layout_constraintStart_toStartOf="@id/imageViewCreditCardBackground"
        app:layout_constraintEnd_toEndOf="@id/imageViewCreditCardBackground"
        app:layout_constraintBottom_toBottomOf="@id/imageViewCreditCardBackground"
        tools:ignore="ContentDescription" />

</androidx.constraintlayout.widget.ConstraintLayout>
