<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="1000dp"
    android:layout_height="676dp"
    tools:context=".pages.CreditCardWaitFragment">

    <!-- TODO: Update blank fragment layout -->
    <TextView
        android:id="@+id/creditwaitMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/creditwaitMessage"
        android:textSize="44sp"
        android:layout_marginTop="50dp"
        android:gravity="center_horizontal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent" />

    <TextView
        android:id="@+id/textViewCreditCardSub"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:text="@string/creditCardTaggingSubMessage"
        android:textSize="29sp"
        android:textColor="@color/gin_grey"
        app:layout_constraintTop_toBottomOf="@+id/creditwaitMessage"
        tools:ignore="SpeakableTextPresentCheck" />


    <TextView
        android:id="@+id/txtPay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/preAmtMessage"
        android:textSize="46sp"
        android:layout_marginStart="-200dp"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/textViewCreditCardSub"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"/>

    <TextView
        android:id="@+id/txtInputAmt"
        android:layout_width="210dp"
        android:layout_height="55dp"
        android:textSize="48sp"
        android:gravity="right|center"
        android:layout_marginStart="20dp"
        app:layout_constraintLeft_toRightOf="@id/txtPay"
        app:layout_constraintTop_toTopOf="@id/txtPay"
        app:layout_constraintBottom_toBottomOf="@id/txtPay"
        tools:ignore="RtlHardcoded" />

    <TextView
        android:id="@+id/won"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/payUnitMessage"
        android:textSize="28sp"
        android:layout_marginTop="15dp"
        android:layout_marginStart="10dp"
        app:layout_constraintLeft_toRightOf="@id/txtInputAmt"
        app:layout_constraintTop_toTopOf="@id/txtInputAmt" />

    <View
        android:id="@+id/textViewLine"
        android:layout_width="460dp"
        android:layout_height="1.5dp"
        android:layout_centerInParent="true"
        android:background="#224E98"
        android:layout_marginTop="5dp"
        app:layout_constraintLeft_toLeftOf="@id/txtPay"
        app:layout_constraintTop_toBottomOf="@id/txtPay" />

    <ImageView
        android:id="@+id/imageViewCreditCardBackground"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/card_to_reader_background"
        android:layout_marginTop="30dp"
        android:layout_marginStart="40dp"
        app:layout_constraintTop_toBottomOf="@id/textViewLine"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:ignore="contentDescription" />

    <ImageView
        android:id="@+id/imgCreditCardTagging"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:importantForAccessibility="no"
        android:background="@drawable/creditcardtagging"
        app:layout_constraintTop_toTopOf="@id/imageViewCreditCardBackground"
        app:layout_constraintStart_toStartOf="@id/imageViewCreditCardBackground"
        app:layout_constraintEnd_toEndOf="@id/imageViewCreditCardBackground"
        app:layout_constraintBottom_toBottomOf="@id/imageViewCreditCardBackground"
        tools:ignore="contentDescription" />


</androidx.constraintlayout.widget.ConstraintLayout>